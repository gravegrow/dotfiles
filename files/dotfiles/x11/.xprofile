# vim:ft=sh

# [ -f "$HOME/.bashrc" ] && source "$HOME/.bashrc"
[ -d "$HOME/.local/bin" ] && PATH="$HOME/.local/bin:$PATH"
[ -d "$HOME/.config/scripts" ] && PATH="$HOME/.config/scripts:$PATH"

export EDITOR=nvim
export TMPDIR=/tmp

# export GTK_THEME=Orchis-Grey-Dark-Compact
export QT_QPA_PLATFORMTHEME=qt6ct
# export QT_STYLE_OVERRIDE=kvantum
# export QT_SCALE_FACTOR=1.15

# export XDG_CURRENT_DESKTOP=DWM
# export XDG_SESSION_DESKTOP=$XDG_CURRENT_DESKTOP
export XDG_DATA_HOME=$HOME/.local/share
export XDG_STATE_HOME=$HOME/.local/state
export XDG_CONFIG_HOME=$HOME/.config
export XDG_CACHE_HOME=$HOME/.cache

export ZDOTDIR="$XDG_CONFIG_HOME/zsh/"

# BEGIN ANSIBLE MANAGED BLOCK
if [ -d "/home/user/.config/dotfiles/files/dwm/bin" ]; then
    PATH="/home/user/.config/dotfiles/files/dwm/bin:$PATH"
fi
# END ANSIBLE MANAGED BLOCK
