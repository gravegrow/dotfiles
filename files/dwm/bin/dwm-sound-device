#!/bin/bash

function rofi-menu() {
    sinks=$(pactl list short sinks | awk '{print $1}')
    sinksArray=($(echo $sinks))
    entries=$(pactl list sinks | grep "device.description" | grep -oP '(?<=")[^"]*')
    selection=$(echo "$entries" | rofi -dmenu -i -theme-str '@import "soundDevice.rasi"' -p "Audio Output" -format 'i')

    if [ -n "$selection" ]; then
        sink=${sinksArray[$selection]}
        pactl set-default-sink "$sink"
    fi
}

case $BUTTON in
1) rofi-menu ;;
esac

bg=#0a0a0a
fg=#8E8E8E

icon="ó°•¾"

printf "^c$fg^^b$bg^$icon"
