#!/bin/bash

case $BUTTON in
1) dwm-volume-change 5%+ ;;
2) dwm-volume-change "toggle" ;;
3) dwm-volume-change 5%- ;;
4) dwm-volume-change 1%+ ;;
5) dwm-volume-change 1%- ;;
esac

bg=#0a0a0a
fg=#807e96
muted_fg=#ED8796

volume=$(wpctl get-volume @DEFAULT_AUDIO_SINK@)

muted() {
	printf "^b$muted_fg^^c$bg^ 箚씇 ^c$bg^^b$bg^ " && exit
}

[[ $volume == *"MUTED"* ]] && muted

volume=${volume#Volume: }
volume=$(printf "%.0f" ${volume//./})

case 1 in
$((volume > 5))) icon="箚빢" ;;
$((volume >= 1))) icon="箚빢 " ;;
*) muted ;;
esac

printf "^c$fg^^b$bg^$icon $volume%%"
